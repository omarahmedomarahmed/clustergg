# ===== Core =====
# Neon pooled connection string. If unset, Cluster runs in DEMO MODE with an
# in-memory Postgres (PGlite) seeded with demo data — fully functional, resets
# on cold start. Set this to a Neon URL for real persistence.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
AUTH_SECRET=change-me-long-random-string
NEXT_PUBLIC_APP_URL=https://clustergg.com

# Optional: token protecting /api/setup (schema init + seed) on a real DB.
SETUP_TOKEN=

# Optional: token required by /api/cron/sync (Vercel Cron sends it automatically
# when CRON_SECRET is set).
CRON_SECRET=

# ===== OAuth sign-in providers (all optional — email/password always works) =====
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Steam sign-in via OpenID needs NO key. STEAM_API_KEY unlocks profile + game stats.
STEAM_API_KEY=

# ===== Game stat APIs (each unlocks its provider; keyless ones work out of the box) =====
RIOT_API_KEY=                 # Valorant / League of Legends / TFT (developer.riotgames.com)
FORTNITE_API_KEY=             # fortnite-api.com (free key)
HYPIXEL_API_KEY=              # Minecraft/Hypixel (developer.hypixel.net)
PUBG_API_KEY=                 # developer.pubg.com
FACEIT_API_KEY=               # CS2 via FACEIT (developers.faceit.com)
SUPERCELL_COC_TOKEN=          # Clash of Clans (developer.clashofclans.com)
SUPERCELL_CR_TOKEN=           # Clash Royale (developer.clashroyale.com)
SUPERCELL_BRAWL_TOKEN=        # Brawl Stars (developer.brawlstars.com)
OPENXBL_API_KEY=              # Xbox Live via xbl.io
BATTLENET_CLIENT_ID=          # Overwatch/WoW (develop.battle.net)
BATTLENET_CLIENT_SECRET=
OSU_CLIENT_ID=                # osu! (osu.ppy.sh/home/account/edit#oauth)
OSU_CLIENT_SECRET=
TRN_API_KEY=                  # tracker.gg network (Apex etc.)
EPIC_CLIENT_ID=               # Epic Online Services
EPIC_CLIENT_SECRET=

# Keyless & live out of the box: Chess.com, Lichess, OpenDota (Dota 2),
# Speedrun.com, Roblox, Steam identity (OpenID).

# ===== Ads / analytics =====
AD_ANALYTICS_SALT=cluster-salt
